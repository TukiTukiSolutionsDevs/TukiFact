# TukiFact Production Environment Variables
# Copy to .env and fill in real values

# PostgreSQL
PG_DATABASE=tukifact
PG_USER=tukifact
PG_PASSWORD=CHANGE_ME_strong_password_here

# JWT
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_secret_key_for_jwt

# MinIO
MINIO_USER=tukifact_minio
MINIO_PASSWORD=CHANGE_ME_minio_password

# SUNAT
SUNAT_ENV=beta  # Change to "production" when ready

# Domain
DOMAIN=tukifact.net.pe

# AI (optional)
AI_PROVIDER=stub
AI_API_KEY=
AI_MODEL=gpt-4o-mini
